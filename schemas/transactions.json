{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["account_id", "amount", "direction", "date"],
    "properties": {
      "account_id": {
        "bsonType": "objectId",
        "description": "Reference to the account"
      },
      "amount": {
        "bsonType": "number",
        "minimum": 0,
        "description": "Transaction amount (positive)"
      },
      "direction": {
        "enum": ["in", "out"],
        "description": "Money in or out"
      },
      "date": {
        "bsonType": "date",
        "description": "When the transaction occurred"
      },
      "category": {
        "bsonType": "string",
        "description": "Optional category label"
      },
      "note": {
        "bsonType": "string",
        "description": "Optional note"
      },
      "created_at": {
        "bsonType": "date",
        "description": "When the transaction was recorded"
      }
    }
  }
}
